# ---------------------------------------------------------------------------
# Mastermind Behavior — Marketing Lead Tracking · environment variables
#
# Add these in Vercel → Project (mb-leads-tracking) → Settings →
# Environment Variables, scoped to **Production** (and Preview if you want
# staging to pull real data too). Each source stays on mock until its vars are
# present; the matching "Data Sources Status" pill flips to Connected on the
# next request, and real numbers appear after the next cron/aggregate run.
#
# Copy to `.env.local` for local development (never commit real secrets).
# ---------------------------------------------------------------------------

# --- Storage (REQUIRED for live data to persist) --------------------------
# Create a Vercel Blob store (Storage tab) and Vercel injects this for you.
# Without it the cron jobs can't write (Vercel's filesystem is read-only) and
# the dashboard stays on mock data.
BLOB_READ_WRITE_TOKEN=

# --- CallRail (cron: every 15 min) ----------------------------------------
CALLRAIL_API_KEY=
CALLRAIL_ACCOUNT_ID=

# --- Webflow Forms (cron: every 15 min) -----------------------------------
# Authoritative forms source: backfills historical submissions and keeps them
# fresh (the Zapier webhook only captures forward in time). Site API token with
# scopes forms:read + sites:read. WEBFLOW_SITE_ID is optional (auto-discovered).
WEBFLOW_API_TOKEN=
# WEBFLOW_SITE_ID=

# --- Calendly (cron: hourly) ----------------------------------------------
# Personal Access Token from Calendly → Integrations → API & Webhooks.
CALENDLY_API_KEY=

# --- Google Business Profile (cron: daily) --------------------------------
# OAuth client + refresh token with Business Profile Performance API access.
# GBP_LOCATION_IDS = comma-separated location IDs for the MANAGED profiles
# only (Hackensack NJ + Warner Robins GA). Unmanaged profiles (Macon GA,
# Lakewood NJ) can't be pulled until claimed.
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REFRESH_TOKEN=
GBP_LOCATION_IDS=

# --- GA4 (cron: daily) ----------------------------------------------------
# GA4_PROPERTY_ID = numeric property id (e.g. 412345678).
# GA4_SERVICE_ACCOUNT_JSON = the service-account key JSON, BASE64-encoded:
#   base64 -w0 service-account.json     (or `base64 -i service-account.json`)
# Grant the service account "Viewer" on the GA4 property.
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# --- Leadtrap (cron: every 15 min) — placeholder --------------------------
# API shape not yet known; wire etl/leadtrap.js once documented.
LEADTRAP_API_KEY=

# --- Cron / refresh auth (OPTIONAL) ---------------------------------------
# If set, Vercel Cron auto-authenticates, BUT the dashboard's manual "Refresh"
# button will get 401 (it doesn't send the secret). Leave UNSET unless you
# want to lock the cron/refresh endpoints — tell me and I'll wire the button
# to pass it.
# CRON_SECRET=
